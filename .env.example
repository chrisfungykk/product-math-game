# Groq API key — SERVER SIDE ONLY. No VITE_ prefix, so it is never bundled into
# the client. Used by the /api/transcribe proxy. Get one at:
# https://console.groq.com/keys
GROQ_API_KEY=

# Optional. Cantonese language code passed to Groq Whisper. Default: yue.
# Set to zh if yue under-performs for your audio.
GROQ_STT_LANG=yue

# Optional. Override the transcription endpoint the browser calls.
# Defaults to /api/transcribe (the bundled serverless proxy).
# When api.groq.com is blocked locally, point to a remote proxy:
#   VITE_STT_ENDPOINT=http://YOUR_VPS_IP:3099/api/transcribe
VITE_STT_ENDPOINT=/api/transcribe
